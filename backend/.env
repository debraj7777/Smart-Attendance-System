PORT=5000
MONGO_URI=mongodb://localhost:27017/smart-attendance
JWT_SECRET=supersecretjwtkey123

# Database configuration:
# By default, the system tries to use a zero-setup in-memory database (USE_IN_MEMORY_DB=true).
# On some Windows systems, if the in-memory database fails to launch, the system automatically falls back to your local MongoDB (via MONGO_URI).
# If you want to force the backend to use your local MongoDB or a MongoDB Atlas URI, set this to false:
USE_IN_MEMORY_DB=true
